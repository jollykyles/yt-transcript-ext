{
  "manifest_version": 3,
  "name": "YouTube Transcript Grabber",
  "version": "1.2.0",
  "description": "Paste a YouTube URL and get the video's subtitles. Prefers user-created subtitles, falls back to English auto-generated.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtu.be/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Get YouTube transcript",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
